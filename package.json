{
  "name": "apicompass",
  "displayName": "APICompass",
  "description": "Automated API Route Visualizer for VS Code — discover, visualize, and navigate REST API routes across Express.js, NestJS, Flask, Django, FastAPI, and Go projects.",
  "version": "0.1.0",
  "publisher": "surya-v",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "api",
    "routes",
    "express",
    "nestjs",
    "flask",
    "django",
    "fastapi",
    "go",
    "golang",
    "rest",
    "navigation",
    "visualization"
  ],
  "activationEvents": [
    "workspaceContains:**/*.js",
    "workspaceContains:**/*.ts",
    "workspaceContains:**/*.py",
    "workspaceContains:**/*.go"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apicompass-explorer",
          "title": "APICompass",
          "icon": "resources/icons/apicompass.svg"
        }
      ]
    },
    "views": {
      "apicompass-explorer": [
        {
          "id": "apicompassRoutesView",
          "name": "API Routes"
        }
      ]
    },
    "commands": [
      {
        "command": "apicompass.refresh",
        "title": "APICompass: Refresh Routes",
        "icon": "$(refresh)"
      },
      {
        "command": "apicompass.navigateToRoute",
        "title": "APICompass: Navigate to Route"
      },
      {
        "command": "apicompass.searchRoutes",
        "title": "APICompass: Search Routes",
        "icon": "$(search)"
      },
      {
        "command": "apicompass.copyRoutePath",
        "title": "APICompass: Copy Route Path"
      },
      {
        "command": "apicompass.copyAsCurl",
        "title": "APICompass: Copy as cURL"
      },
      {
        "command": "apicompass.exportJson",
        "title": "APICompass: Export Routes as JSON",
        "icon": "$(json)"
      },
      {
        "command": "apicompass.exportOpenApi",
        "title": "APICompass: Export Routes as OpenAPI",
        "icon": "$(file-code)"
      }
    ],
    "keybindings": [
      {
        "command": "apicompass.refresh",
        "key": "ctrl+shift+a r",
        "mac": "cmd+shift+a r",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "apicompass.searchRoutes",
        "key": "ctrl+shift+a s",
        "mac": "cmd+shift+a s",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "apicompass.refresh",
          "when": "view == apicompassRoutesView",
          "group": "navigation"
        },
        {
          "command": "apicompass.searchRoutes",
          "when": "view == apicompassRoutesView",
          "group": "navigation"
        },
        {
          "command": "apicompass.exportJson",
          "when": "view == apicompassRoutesView",
          "group": "export"
        },
        {
          "command": "apicompass.exportOpenApi",
          "when": "view == apicompassRoutesView",
          "group": "export"
        }
      ],
      "view/item/context": [
        {
          "command": "apicompass.copyRoutePath",
          "when": "view == apicompassRoutesView && viewItem == route",
          "group": "clipboard"
        },
        {
          "command": "apicompass.copyAsCurl",
          "when": "view == apicompassRoutesView && viewItem == route",
          "group": "clipboard"
        }
      ]
    },
    "configuration": {
      "title": "APICompass",
      "properties": {
        "apicompass.includePaths": {
          "type": "array",
          "default": [],
          "description": "Glob patterns for folders to include when scanning (empty = scan everything)."
        },
        "apicompass.excludePaths": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/venv/**",
            "**/__pycache__/**",
            "**/dist/**",
            "**/build/**"
          ],
          "description": "Glob patterns for folders to exclude when scanning."
        },
        "apicompass.enabledFrameworks": {
          "type": "array",
          "default": [
            "express",
            "flask",
            "django",
            "fastapi",
            "go",
            "nestjs"
          ],
          "description": "Frameworks to scan for (express, flask, django, fastapi, go, nestjs)."
        },
        "apicompass.groupBy": {
          "type": "string",
          "enum": [
            "file",
            "method",
            "framework"
          ],
          "default": "file",
          "description": "How to group routes in the tree view."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src --ext ts",
    "test": "jest --config jest.config.js",
    "test:coverage": "jest --config jest.config.js --coverage",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
